# =============================================================================
# SICOF — Variables de Entorno
# Copiar este archivo a `.env` y ajustar los valores para el entorno objetivo.
# NUNCA commitear el archivo `.env` con credenciales reales.
# =============================================================================

# ── Motor de base de datos ────────────────────────────────────────────────────
# Activar PostgreSQL/TimescaleDB (poner "true" en staging/producción)
# Si no se define o es distinto de "true", se usa SQLite (desarrollo local)
SICOF_USE_POSTGRES=true

# ── Conexión PostgreSQL/TimescaleDB ──────────────────────────────────────────
# Valores por defecto compatibles con el docker-compose.yml incluido
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=sicof
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sicof2026

# ── SOA Bus ───────────────────────────────────────────────────────────────────
# Host y puerto del bus SOA (modificar si los servicios corren en otro host)
SOA_BUS_HOST=localhost
SOA_BUS_PORT=5000
